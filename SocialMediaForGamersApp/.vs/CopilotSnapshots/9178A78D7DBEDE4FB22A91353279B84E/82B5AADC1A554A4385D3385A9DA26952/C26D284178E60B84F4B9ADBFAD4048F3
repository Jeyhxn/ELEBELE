/* Ensure navbar takes up the full width */
.navbar {
    background-color: #1b1b1f;
    color: white;
    padding: 1rem 0;
    box-shadow: none;
    border-bottom: 1px solid #2a2a2e;
    width: 100%;
    margin: 0;
}

.nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
}

.nav-logo-link {
    display: flex;
    align-items: center;
}

.nav-logo-text {
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: 0.35em;
    color: #67707b;
    border: 1px solid #67707b;
    padding: 0.15rem 0.5rem;
    line-height: 1;
    user-select: none;
    text-transform: uppercase;
    white-space: nowrap;
    transition: color 0.2s, border-color 0.2s;
}

.nav-logo-text:hover {
    color: #c6d4df;
    border-color: #c6d4df;
}

.nav-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
}

/* Icon-only navigation links */
.nav-icon-link {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    transition: background 0.2s;
}

.nav-icon-link:hover {
    background: rgba(255, 255, 255, 0.1);
}

.nav-icon {
    width: 22px;
    height: 22px;
    object-fit: contain;
    filter: brightness(0) invert(1);
}

.nav-icon-emoji {
    font-size: 1.3rem;
    line-height: 1;
}

.auth-links {
  display: flex;
  gap: 0.5rem;
}

.login-link, .register-link {
  text-decoration: none;
  padding: 0.55rem 1.25rem;
  border-radius: 6px;
  font-weight: 600;
  font-size: 0.9rem;
  transition: all 0.2s;
}

.login-link {
  background: transparent;
  border: 1px solid #3a3a40;
  color: #d7dadc !important;
}

.login-link:hover {
  background-color: #2d2d33;
  border-color: #4a4a52;
  color: #fff !important;
}

.register-link {
  background-color: #2d2d33;
  border: 1px solid #3a3a40;
  color: #fff !important;
}

.register-link:hover {
  background-color: #3a3a40;
}

.user-menu {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.user-greeting {
  color: white;
  font-weight: 600;
}

.logout-button {
  background-color: #ff6b6b;
  color: white;
  border: none;
  padding: 0.75rem 1.5rem;
  border-radius: 4px;
  cursor: pointer;
  font-weight: 600;
  transition: background-color 0.3s;
}

.logout-button:hover {
  background-color: #ff5252;
}

.nav-menu {
  list-style: none;
  display: flex;
  gap: 2rem;
}

.nav-menu a {
  color: white;
  text-decoration: none;
  transition: color 0.3s;
}

.nav-menu a:hover {
  color: #00d4ff;
}

/* Notification badge */
.notif-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: #ff4444;
    color: white;
    font-size: 0.6rem;
    font-weight: 700;
    min-width: 16px;
    height: 16px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    line-height: 1;
    border: 2px solid #1b1b1f;
}

/* Profile dropdown */
.pd-wrap {
    position: relative;
    z-index: 1100;
}

.pd-trigger {
    background: none;
    border: 2px solid transparent;
    border-radius: 50%;
    padding: 2px;
    cursor: pointer;
    transition: border-color 0.15s;
}

.pd-trigger:hover {
    border-color: rgba(255, 255, 255, 0.3);
}

.pd-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: white;
    font-weight: 700;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    justify-content: center;
}

.pd-dropdown {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  width: 240px;
  background: #1a1a1b;
  border: 1px solid #343536;
  border-radius: 12px;
  box-shadow: 0 8px 28px rgba(0, 0, 0, 0.55);
  overflow: hidden;
  padding: 0.4rem 0;
  animation: dropdown-fade-in 0.18s ease-out;
}

.pd-item {
  display: flex;
  align-items: center;
  gap: 0.7rem;
  padding: 0.6rem 1rem;
  text-decoration: none;
  color: #d7dadc;
  cursor: pointer;
  transition: background 0.12s;
  background: none;
  border: none;
  width: 100%;
  font-size: 0.88rem;
  text-align: left;
}

.pd-item:hover {
  background: #272729;
}

.pd-item-icon {
  width: 20px;
  height: 20px;
  object-fit: contain;
  flex-shrink: 0;
  filter: brightness(0) invert(0.85);
}

.pd-item-body {
  display: flex;
  flex-direction: column;
  gap: 0.05rem;
  min-width: 0;
}

.pd-item-label {
  font-weight: 500;
  color: #d7dadc;
}

.pd-item-sub {
  font-size: 0.75rem;
  color: #818384;
}

.pd-divider {
  height: 1px;
  background: #343536;
  margin: 0.3rem 0;
}

.pd-logout .pd-item-label {
  color: #ff6b6b;
}

/* Search bar */
.sb-wrap {
    position: relative;
    flex: 1;
    max-width: 440px;
    z-index: 1000;
}

.sb-input-row {
  display: flex;
  align-items: center;
  background: #272729;
  border: 1px solid #343536;
  border-radius: 20px;
  padding: 0 0.75rem;
  transition: border-color 0.2s, background 0.2s;
}

.sb-input-row.focused {
  border-color: #d7dadc;
  background: #1a1a1b;
  border-radius: 20px 20px 0 0;
}

.sb-icon {
  width: 16px;
  height: 16px;
  object-fit: contain;
  flex-shrink: 0;
  margin-right: 0.4rem;
  pointer-events: none;
  filter: brightness(0) invert(1);
  opacity: 1;
}

.sb-input {
  flex: 1;
  background: none;
  border: none;
  outline: none;
  color: #d7dadc;
  font-size: 0.9rem;
  padding: 0.55rem 0;
}

.sb-input::placeholder {
  color: #818384;
}

.sb-clear {
  background: none;
  border: none;
  color: #818384;
  font-size: 0.8rem;
  cursor: pointer;
  padding: 0.2rem 0.3rem;
  border-radius: 50%;
  line-height: 1;
  transition: color 0.15s;
  flex-shrink: 0;
}

.sb-clear:hover {
  color: #d7dadc;
}

.sb-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: #1a1a1b;
  border: 1px solid #343536;
  border-top: none;
  border-radius: 0 0 16px 16px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
  overflow: hidden;
  padding-bottom: 0.5rem;
  animation: dropdown-fade-in 0.18s ease-out;
}

.sb-section {
  padding: 0.5rem 0 0;
}

.sb-section-label {
  display: block;
  font-size: 0.72rem;
  font-weight: 700;
  color: #818384;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 0.3rem 1rem 0.15rem;
}

.sb-row {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  padding: 0.55rem 1rem;
  cursor: pointer;
  transition: background 0.12s;
}

.sb-row:hover {
  background: #272729;
}

.sb-row-icon {
  font-size: 1rem;
  flex-shrink: 0;
  width: 22px;
  text-align: center;
}

.sb-clock { color: #818384; }
.sb-trend { color: #818384; font-style: normal; }
.sb-comm-icon { color: #4fbcff; }
.sb-post-icon { color: #cc8b37; }

.sb-row-text {
  flex: 1;
  font-size: 0.88rem;
  color: #d7dadc;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sb-trend-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.05rem;
  min-width: 0;
}

.sb-row-sub {
  font-size: 0.73rem;
  color: #818384;
}

.sb-remove {
  background: none;
  border: 1px solid #343536;
  border-radius: 50%;
  color: #818384;
  font-size: 0.7rem;
  cursor: pointer;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.12s;
}

.sb-remove:hover {
  background: #343536;
  color: #d7dadc;
}

@media (max-width: 768px) {
  .sb-wrap {
    max-width: 200px;
  }
}

@keyframes dropdown-fade-in {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}
