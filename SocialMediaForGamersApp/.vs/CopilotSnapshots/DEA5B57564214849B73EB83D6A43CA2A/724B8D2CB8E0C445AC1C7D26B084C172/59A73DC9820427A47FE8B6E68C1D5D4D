import axios from 'axios'

// Your .NET API is running on port 7271
const API_BASE = 'https://localhost:7271/api'

const apiClient = axios.create({
  baseURL: API_BASE,
  headers: {
    'Content-Type': 'application/json',
  },
  withCredentials: false,
})

// Error handler with detailed logging
apiClient.interceptors.response.use(
  response => {
    console.log('✅ API Response:', response.config.url, response.status)
    return response
  },
  error => {
    console.error('❌ API Error Details:')
    console.error('  Base URL:', API_BASE)
    console.error('  Request URL:', error.config?.url)
    console.error('  Status:', error.response?.status)
    console.error('  Message:', error.message)
    console.error('  Full Error:', error)
    return Promise.reject(error)
  }
)

// Test connection
export const testConnection = async () => {
  try {
    console.log('Testing connection to:', API_BASE)
    const response = await apiClient.get('/category?page=1&take=1')
    return { success: true, message: `✅ Connected to ${API_BASE}` }
  } catch (err) {
    console.error('Connection failed:', err.message)
    return { success: false, message: `❌ Cannot connect to ${API_BASE}: ${err.message}` }
  }
}

// Categories
export const getCategories = (page = 1, take = 10) =>
  apiClient.get('/category', { params: { page, take } })

export const getCategoryById = (id) =>
  apiClient.get(`/category/${id}`)

export const createCategory = (data) =>
  apiClient.post('/category', data)

export const deleteCategory = (id) =>
  apiClient.delete(`/category/${id}`)

// Games
export const getGames = (page = 1, take = 20, filters = {}) => {
  const params = { page, take }
  if (filters.categoryId) params.categoryId = filters.categoryId
  if (filters.platformIds?.length) {
    filters.platformIds.forEach(id => {
      params[`platformIds`] = params[`platformIds`] || []
    })
  }
  // Build query string manually for array params
  let queryParts = [`page=${page}`, `take=${take}`]
  if (filters.search) queryParts.push(`search=${encodeURIComponent(filters.search)}`)
  if (filters.categoryId) queryParts.push(`categoryId=${filters.categoryId}`)
  if (filters.platformIds?.length) filters.platformIds.forEach(id => queryParts.push(`platformIds=${id}`))
  if (filters.tagIds?.length) filters.tagIds.forEach(id => queryParts.push(`tagIds=${id}`))
  return apiClient.get(`/game?${queryParts.join('&')}`)
}

export const getGameById = (id) =>
  apiClient.get(`/game/${id}`)

export const getGameCreationOptions = () =>
  apiClient.get('/game/creation-options')

export const createGame = (data) => {
  const isFormData = data instanceof FormData
  return apiClient.post('/game', data, {
    headers: isFormData ? { 'Content-Type': 'multipart/form-data' } : {}
  })
}

export const updateGame = (id, data) =>
  apiClient.put(`/game/${id}`, data)

export const deleteGame = (id) =>
  apiClient.delete(`/game/${id}`)

