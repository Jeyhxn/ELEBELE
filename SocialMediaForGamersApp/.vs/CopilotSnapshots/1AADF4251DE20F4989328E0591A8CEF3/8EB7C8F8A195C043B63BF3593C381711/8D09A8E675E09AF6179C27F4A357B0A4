import { useState, useMemo } from 'react'
import { useNavigate, Navigate } from 'react-router-dom'
import { useFavorites } from '../context/FavoriteContext'
import { useAuth } from '../context/AuthContext'

const SORT_OPTIONS = [
  { key: 'custom', label: 'Your Order' },
  { key: 'name', label: 'Name' },
  { key: 'date-added', label: 'Date Added' },
  { key: 'rating', label: 'Rating' },
]

export default function FavoritesPage() {
  const navigate = useNavigate()
  const { user, loading } = useAuth()
  const { favorites, removeFavorite } = useFavorites()
  const [search, setSearch] = useState('')
  const [sortKey, setSortKey] = useState('custom')
  const [showSortMenu, setShowSortMenu] = useState(false)

  if (loading) {
    return <div className="loading">Loading...</div>
  }

  if (!user) {
    return <Navigate to="/login" replace />
  }

  const getImageUrl = (imageURL, gameName) => {
    if (!imageURL) return getPlaceholderImage(gameName)
    if (imageURL.startsWith('http')) return imageURL
    return `https://localhost:7271/images/${imageURL}`
  }

  const getPlaceholderImage = (gameName) => {
    const colors = ['FF6B6B', '4ECDC4', '45B7D1', 'FFA07A', '98D8C8', 'F7DC6F', 'BB8FCE', '85C1E2']
    const hash = (gameName || '').charCodeAt(0) || 0
    const color = colors[hash % colors.length]
    return `https://via.placeholder.com/292x136/${color}/FFFFFF?text=${encodeURIComponent(gameName || 'Game')}`
  }

  const filtered = useMemo(() => {
    let list = [...favorites]

    if (search.trim()) {
      const q = search.toLowerCase()
      list = list.filter(g =>
        g.name?.toLowerCase().includes(q) ||
        g.category?.name?.toLowerCase().includes(q) ||
        g.gameTags?.some(gt => gt.tag?.name?.toLowerCase().includes(q))
      )
    }

    if (sortKey === 'name') list.sort((a, b) => (a.name || '').localeCompare(b.name || ''))
    else if (sortKey === 'rating') list.sort((a, b) => (b.rating || 0) - (a.rating || 0))

    return list
  }, [favorites, search, sortKey])

  const sortLabel = SORT_OPTIONS.find(s => s.key === sortKey)?.label || 'Your Order'

  return (
    <div className="wl-page">
      {/* Header */}
      <div className="wl-header">
        <div className="wl-header-avatar">
          {(user.username || user.email || '?')[0].toUpperCase()}
        </div>
        <div className="wl-header-info">
          <h1 className="wl-header-title">
            {(user.username || user.email || 'User').toUpperCase()}'S WISHLIST
          </h1>
        </div>
      </div>

      {/* Toolbar */}
      <div className="wl-toolbar">
        <div className="wl-search-wrap">
          <img src="/assets/icons/search.png" alt="" className="wl-search-icon" />
          <input
            className="wl-search"
            type="text"
            placeholder="Search by name or tag"
            value={search}
            onChange={e => setSearch(e.target.value)}
          />
        </div>
        <div className="wl-sort-wrap">
          <button className="wl-sort-btn" onClick={() => setShowSortMenu(!showSortMenu)}>
            Sort: <strong>{sortLabel}</strong>
            <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M4 6l4 4 4-4"/></svg>
          </button>
          {showSortMenu && (
            <div className="wl-sort-menu">
              {SORT_OPTIONS.map(s => (
                <button
                  key={s.key}
                  className={`wl-sort-option ${sortKey === s.key ? 'active' : ''}`}
                  onClick={() => { setSortKey(s.key); setShowSortMenu(false) }}
                >
                  {s.label}
                </button>
              ))}
            </div>
          )}
        </div>
      </div>

      {/* List */}
      {filtered.length === 0 ? (
        <div className="wl-empty">
          {favorites.length === 0
            ? <p>Your wishlist is empty. Browse games and add some!</p>
            : <p>No games match your search.</p>
          }
          <button className="wl-browse-btn" onClick={() => navigate('/')}>Browse Games</button>
        </div>
      ) : (
        <div className="wl-list">
          {filtered.map((game, idx) => {
            const hasTags = game.gameTags && game.gameTags.length > 0
            const hasCategory = game.category && game.category.name
            const hasPlatforms = game.gamePlatforms && game.gamePlatforms.length > 0

            return (
              <div
                key={game.id}
                className="wl-item"
                onClick={() => navigate(`/game/${game.id}`)}
              >
                <div className="wl-item-rank">
                  <span className="wl-rank-num">{idx + 1}</span>
                </div>

                <div className="wl-item-img">
                  <img
                    src={getImageUrl(game.imageURL, game.name)}
                    alt={game.name}
                    onError={e => { e.target.src = getPlaceholderImage(game.name) }}
                  />
                </div>

                <div className="wl-item-body">
                  <h3 className="wl-item-title">{game.name}</h3>

                  {(hasTags || hasCategory) && (
                    <div className="wl-item-tags">
                      {hasCategory && <span className="wl-tag">{game.category.name}</span>}
                      {hasTags && game.gameTags.slice(0, 5).map((gt, i) => (
                        <span key={gt.id || i} className="wl-tag">{gt.tag?.name || `Tag`}</span>
                      ))}
                    </div>
                  )}

                  <div className="wl-item-meta-row">
                    {game.releaseDate && (
                      <span className="wl-item-meta">
                        <span className="wl-meta-label">RELEASE DATE:</span>{' '}
                        {new Date(game.releaseDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                      </span>
                    )}
                    {hasPlatforms && (
                      <span className="wl-item-platforms">
                        {game.gamePlatforms.map((gp, i) => (
                          <span key={gp.id || i} className="wl-platform-chip">
                            {gp.platform?.name || 'PC'}
                          </span>
                        ))}
                      </span>
                    )}
                  </div>
                </div>

                <div className="wl-item-right">
                  <button
                    className="wl-remove-btn"
                    onClick={e => { e.stopPropagation(); removeFavorite(game.id) }}
                    title="Remove from wishlist"
                  >
                    Remove
                  </button>
                </div>
              </div>
            )
          })}
        </div>
      )}
    </div>
  )
}
