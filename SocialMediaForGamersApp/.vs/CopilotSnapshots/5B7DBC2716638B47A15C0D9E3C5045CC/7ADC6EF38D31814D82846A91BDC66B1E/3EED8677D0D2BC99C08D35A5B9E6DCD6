  padding: 0.25rem 0.6rem;
  border-radius: 12px;
  font-size: 0.8rem;
  font-weight: 600;
  background: #f0f0f0;
  color: #666;
}

.admin-badge.admin {
  background: #fff3e0;
  color: #e65100;
}

/* success feedback */
