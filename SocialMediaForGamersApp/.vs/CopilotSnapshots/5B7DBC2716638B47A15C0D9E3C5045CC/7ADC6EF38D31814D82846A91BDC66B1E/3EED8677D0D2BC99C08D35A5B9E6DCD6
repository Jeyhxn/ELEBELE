  .form-row {
    grid-template-columns: 1fr;
  }

  .auth-card h1 {
    font-size: 1.5rem;
  }
}

/* About This Game (legacy, kept for compatibility) */
.about-this-game {
  margin-top: 2rem;
  background: rgba(0, 0, 0, 0.2);
  padding: 1.25rem;
  border-radius: 3px;
}

.about-this-game h2 {
  font-size: 1.1rem;
  font-weight: 400;
  color: #fff;
  margin: 0 0 0.75rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.about-this-game p {
  color: #acb2b8;
  line-height: 1.7;
  font-size: 0.88rem;
  white-space: pre-wrap;
}

/* Steam-style Reviews Section */
.sr-section {
  margin-top: 2rem;
}

.sr-heading {
  font-size: 1.1rem;
  font-weight: 400;
  color: #fff;
  margin: 0 0 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.sr-login-prompt {
  color: #8f98a0;
  font-size: 0.9rem;
  margin-bottom: 1.5rem;
}

.sr-login-prompt a {
  color: #67c1f5;
  text-decoration: none;
  font-weight: 600;
}

.sr-login-prompt a:hover {
  color: #fff;
}

/* Review form */
.sr-form {
  background: rgba(0, 0, 0, 0.2);
  border-radius: 3px;
  padding: 1rem;
  margin-bottom: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.sr-form-sentiment {
  display: flex;
  gap: 0.5rem;
}

.sr-sentiment-btn {
  padding: 0.45rem 1rem;
  border: 1px solid #3a3a42;
  border-radius: 3px;
  background: #1b2838;
  color: #8f98a0;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
}

.sr-sentiment-btn:hover {
  background: #2a475e;
  color: #c7d5e0;
}

.sr-sentiment-btn.active.positive {
  background: #1a3a4a;
  border-color: #4e8fb5;
  color: #67c1f5;
}

.sr-sentiment-btn.active.negative {
  background: #3a1a1a;
  border-color: #a84e4e;
  color: #d9534f;
}

.sr-form-textarea {
  width: 100%;
  padding: 0.65rem 0.75rem;
  background: #1b2838;
  border: 1px solid #3a3a42;
  border-radius: 3px;
  color: #c7d5e0;
  font-size: 0.9rem;
  font-family: inherit;
  resize: vertical;
  outline: none;
  transition: border-color 0.2s;
}

.sr-form-textarea:focus {
  border-color: #67c1f5;
}

.sr-form-textarea::placeholder {
  color: #556772;
}

.sr-form-submit {
  align-self: flex-end;
  padding: 0.45rem 1.25rem;
  background: linear-gradient(to right, #47bfff 5%, #1a44c2 60%);
  border: none;
  border-radius: 2px;
  color: #fff;
  font-size: 0.85rem;
  font-weight: 500;
  cursor: pointer;
  transition: filter 0.15s;
}

.sr-form-submit:hover:not(:disabled) {
  filter: brightness(1.15);
}

.sr-form-submit:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

/* Review list */
.sr-list {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.sr-empty {
  text-align: center;
  color: #556772;
  padding: 2rem 0;
  font-size: 0.9rem;
}

/* Review card — Steam layout */
.sr-card {
  display: flex;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 0;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.04);
}

.sr-card-left {
  flex: 0 0 184px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.3rem;
  padding: 0.85rem 0.75rem;
  background: rgba(0, 0, 0, 0.15);
  border-right: 1px solid rgba(255, 255, 255, 0.04);
}

.sr-avatar {
  width: 36px;
  height: 36px;
  border-radius: 2px;
  background: #3a3a42;
  color: #c7d5e0;
  font-weight: 700;
  font-size: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sr-username {
  font-size: 0.82rem;
  color: #c7d5e0;
  font-weight: 600;
  text-align: center;
  word-break: break-word;
}

.sr-review-count {
  font-size: 0.7rem;
  color: #556772;
}

.sr-card-right {
  flex: 1;
  padding: 0;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

/* Verdict header bar (blue for positive, red tint for negative) */
.sr-verdict {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0.85rem;
}

.sr-verdict.positive {
  background: linear-gradient(135deg, #1a3a4a 0%, #142e3e 100%);
}

.sr-verdict.negative {
  background: linear-gradient(135deg, #3a1a1a 0%, #2e1414 100%);
}

.sr-verdict-icon {
  font-size: 1.3rem;
}

.sr-verdict-text {
  font-size: 0.95rem;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.sr-verdict.positive .sr-verdict-text {
  color: #67c1f5;
}

.sr-verdict.negative .sr-verdict-text {
  color: #d9534f;
}

.sr-date {
  font-size: 0.72rem;
  color: #556772;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding: 0.35rem 0.85rem 0.15rem;
}

.sr-review-text {
  font-size: 0.88rem;
  color: #acb2b8;
  line-height: 1.6;
  padding: 0.4rem 0.85rem 0.75rem;
  margin: 0;
  white-space: pre-wrap;
}

/* Edit form inside card */
.sr-edit-form {
  padding: 0.6rem 0.85rem 0.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.sr-edit-actions {
  display: flex;
  gap: 0.5rem;
}

.sr-edit-cancel {
  padding: 0.45rem 1.25rem;
  background: #2a2a2e;
  border: 1px solid #3a3a42;
  border-radius: 2px;
  color: #8f98a0;
  font-size: 0.85rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.15s;
}

.sr-edit-cancel:hover {
  background: #3a3a42;
  color: #c7d5e0;
}

/* Actions row */
.sr-actions {
  display: flex;
  gap: 0.4rem;
  padding: 0 0.85rem 0.65rem;
  border-top: 1px solid rgba(255, 255, 255, 0.04);
  padding-top: 0.5rem;
}

.sr-action-btn {
  background: none;
  border: 1px solid #3a3a42;
  border-radius: 2px;
  color: #8f98a0;
  font-size: 0.78rem;
  font-weight: 500;
  padding: 0.3rem 0.65rem;
  cursor: pointer;
  transition: all 0.15s;
}

.sr-action-btn:hover {
  background: #2a475e;
  border-color: #4e8fb5;
  color: #c7d5e0;
}

.sr-action-delete:hover {
  background: #3a1a1a;
  border-color: #a84e4e;
  color: #d9534f;
}

@media (max-width: 600px) {
  .sr-card {
    flex-direction: column;
  }

  .sr-card-left {
    flex: none;
    flex-direction: row;
    padding: 0.6rem 0.85rem;
    border-right: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .sr-avatar {
    width: 28px;
    height: 28px;
    font-size: 0.8rem;
  }
}

/* Game Image Gallery */
.image-thumbnails {
  display: flex;
  gap: 0.5rem;
  margin-top: 0.75rem;
  flex-wrap: wrap;
}

.thumbnail {
  width: 60px;
  height: 60px;
  border-radius: 6px;
  overflow: hidden;
  cursor: pointer;
  border: 2px solid transparent;
  transition: border-color 0.2s, opacity 0.2s;
  opacity: 0.6;
}

.thumbnail:hover {
  opacity: 1;
}

.thumbnail.active {
  border-color: #00d4ff;
  opacity: 1;
}

.thumbnail img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ===== Admin Panel ===== */
.admin-panel {
  max-width: 1200px;
