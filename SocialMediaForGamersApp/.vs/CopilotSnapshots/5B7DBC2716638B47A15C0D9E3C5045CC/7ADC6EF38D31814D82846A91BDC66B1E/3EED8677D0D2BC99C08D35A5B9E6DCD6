.checkbox-item:hover {
  border-color: #764ba2;
}

.checkbox-item.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
  color: white;
}

.checkbox-item input[type="checkbox"] {
  display: none;
}

.no-options {
