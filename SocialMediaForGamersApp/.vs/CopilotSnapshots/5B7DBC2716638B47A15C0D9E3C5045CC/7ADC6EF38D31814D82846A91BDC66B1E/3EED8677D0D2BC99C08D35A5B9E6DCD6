}

.stat-label {
  font-size: 0.8rem;
  color: #555;
  font-weight: 500;
}

/* Section headers */
.admin-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.25rem;
}

.admin-section-header h2 {
  font-size: 1.2rem;
  color: #d7dadc;
}

.admin-section-header button {
  padding: 0.5rem 1.25rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 6px;
  font-weight: 600;
  cursor: pointer;
  transition: opacity 0.2s;
}

.admin-section-header button:hover {
  opacity: 0.85;
}

/* Inline form */
.admin-inline-form {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
}

.admin-inline-form input {
  flex: 1;
  padding: 0.5rem 0.75rem;
  border: 2px solid #ddd;
  border-radius: 6px;
  font-size: 0.95rem;
  margin: 0;
}

.admin-inline-form input:focus {
  outline: none;
  border-color: #764ba2;
}

.admin-inline-form button {
  padding: 0.5rem 1.25rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 6px;
  font-weight: 600;
  cursor: pointer;
}

/* Game creation form */
.admin-form {
  background: #1b1b1f;
  border: 1px solid #2a2a2e;
  border-radius: 10px;
  padding: 1.25rem;
  margin-bottom: 1.5rem;
}

.admin-form h3 {
  margin-bottom: 1rem;
  color: #d7dadc;
}

.admin-form-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1rem;
  margin-bottom: 1rem;
}

.admin-form .form-group {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.admin-form .form-group label {
  font-size: 0.85rem;
  font-weight: 600;
  color: #8f98a0;
}

.admin-form .form-group input,
.admin-form .form-group textarea,
.admin-form .form-group select {
  padding: 0.5rem 0.75rem;
  border: 2px solid #3a3a42;
  border-radius: 6px;
  font-size: 0.9rem;
  font-family: inherit;
  margin: 0;
  background: #1b1b1f;
  color: #d7dadc;
}

.admin-form .form-group input:focus,
.admin-form .form-group textarea:focus,
.admin-form .form-group select:focus {
