  outline: none;
  line-height: 1.45;
  transition: border-color 0.2s;
}

.pd-comment-edit-input:focus {
  border-color: #d7dadc;
}

.pd-comment-edit-actions {
  display: flex;
  gap: 0.4rem;
}

.pd-comment-edit-save {
  background: #0079d3;
  border: none;
  color: white;
  padding: 0.3rem 0.85rem;
  border-radius: 14px;
  font-weight: 700;
  font-size: 0.78rem;
  cursor: pointer;
  transition: background 0.15s;
}

.pd-comment-edit-save:hover {
  background: #1a8cff;
}

.pd-comment-edit-save:disabled {
  opacity: 0.5;
  cursor: default;
}

.pd-comment-edit-cancel {
  background: #272729;
  border: none;
  color: #818384;
  padding: 0.3rem 0.85rem;
  border-radius: 14px;
  font-weight: 600;
  font-size: 0.78rem;
  cursor: pointer;
  transition: background 0.15s;
}

.pd-comment-edit-cancel:hover {
  background: #3a3a3c;
  color: #d7dadc;
}

/* Reply form */
.pd-reply-form {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-top: 0.4rem;
  margin-bottom: 0.25rem;
}

.pd-reply-avatar {
  width: 22px;
  height: 22px;
  font-size: 0.65rem;
}

.pd-reply-input {
  flex: 1;
  background: #272729;
  border: 1px solid #343536;
  border-radius: 16px;
  padding: 0.4rem 0.75rem;
  color: #d7dadc;
  font-size: 0.82rem;
  outline: none;
  transition: border-color 0.2s;
}

.pd-reply-input::placeholder {
  color: #5a5c5e;
}

.pd-reply-input:focus {
  border-color: #d7dadc;
}

.pd-reply-submit {
  padding: 0.3rem 0.75rem;
  font-size: 0.76rem;
}

/* Nested replies */
.pd-replies {
  margin-top: 0.15rem;
}
