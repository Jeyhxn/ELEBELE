}

.admin-tabs {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 1.5rem;
  border-bottom: 2px solid #2a2a2e;
  padding-bottom: 0.75rem;
}

.admin-tab-btn {
  padding: 0.6rem 1.25rem;
  border: 2px solid #3a3a42;
  border-radius: 6px;
  background: #25252a;
  color: #8f98a0;
  font-weight: 600;
  font-size: 0.9rem;
