}

.post-vote-btn:disabled {
  opacity: 0.3;
  cursor: default;
}

.post-vote-count {
  font-weight: 700;
  font-size: 0.82rem;
  color: #555;
  min-width: 12px;
  text-align: center;
}

/* Post body */
.post-body {
  flex: 1;
  padding: 0.75rem 1rem;
  min-width: 0;
}

.post-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  font-size: 0.78rem;
  color: #888;
  margin-bottom: 0.4rem;
}

.post-author {
  font-weight: 600;
  color: #555;
}

.post-game {
  background: #e3f2fd;
  color: #1565c0;
  padding: 0.1rem 0.4rem;
  border-radius: 4px;
  font-weight: 600;
}

.post-title {
  font-size: 1.05rem;
  color: #1a1a1a;
  margin-bottom: 0.35rem;
}

.post-content {
  font-size: 0.9rem;
  color: #444;
  line-height: 1.5;
  margin-bottom: 0.5rem;
  white-space: pre-wrap;
}

.post-image {
  margin-bottom: 0.5rem;
  border-radius: 8px;
  overflow: hidden;
  max-height: 400px;
}

.post-image img {
  width: 100%;
  object-fit: cover;
  display: block;
}

/* Post actions bar */
.post-actions-bar {
  display: flex;
  gap: 0.75rem;
}

.post-action-btn {
  background: none;
  border: none;
  color: #888;
  font-size: 0.8rem;
  font-weight: 600;
  cursor: pointer;
  padding: 0.3rem 0.5rem;
  border-radius: 4px;
  transition: background 0.15s;
}

.post-action-btn:hover {
  background: #f5f5f5;
  color: #555;
}

.post-action-btn.delete:hover {
  background: #ffebee;
  color: #c62828;
}

/* Comments */
.post-comments {
  margin-top: 0.75rem;
  padding-top: 0.75rem;
  border-top: 1px solid #eee;
}

.post-comment {
  padding: 0.5rem 0;
  border-bottom: 1px solid #f5f5f5;
}

.post-comment:last-of-type {
  border-bottom: none;
}

.comment-author {
  font-weight: 600;
  font-size: 0.8rem;
  color: #555;
  margin-right: 0.5rem;
}

.comment-time {
  font-size: 0.75rem;
  color: #aaa;
}

.post-comment p {
  font-size: 0.85rem;
  color: #444;
  margin-top: 0.2rem;
  line-height: 1.4;
}

.comment-form {
  display: flex;
  gap: 0.5rem;
  margin-top: 0.75rem;
}

.comment-form input {
  flex: 1;
  padding: 0.5rem 0.75rem;
  border: 2px solid #ddd;
  border-radius: 20px;
  font-size: 0.85rem;
  margin: 0;
}

.comment-form input:focus {
  outline: none;
  border-color: #2196F3;
  box-shadow: none;
}

.comment-form button {
  padding: 0.5rem 1rem;
  background: #2196F3;
  color: white;
  border: none;
  border-radius: 20px;
  font-weight: 600;
  font-size: 0.8rem;
  cursor: pointer;
}

.comment-form button:disabled {
  opacity: 0.5;
  cursor: default;
}

.login-prompt {
  color: #999;
  font-size: 0.85rem;
  font-style: italic;
  margin-top: 0.5rem;
}

.empty-feed {
  text-align: center;
  padding: 3rem 1rem;
  color: #888;
  background: white;
  border-radius: 10px;
}

.posts-feed {
  display: flex;
  flex-direction: column;
}

/* Community sidebar rows & join buttons */
.sidebar-community-row {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

.sidebar-community-row .sidebar-community-item {
  flex: 1;
  min-width: 0;
}

.sidebar-community-count {
  margin-left: auto;
  font-size: 0.75rem;
  color: #aaa;
  font-weight: 400;
}

.community-join-btn {
  padding: 0.2rem 0.5rem;
  border: 2px solid #2196F3;
  border-radius: 14px;
  background: white;
  color: #2196F3;
  font-size: 0.7rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
  flex-shrink: 0;
}

.community-join-btn:hover {
  background: #2196F3;
  color: white;
}

.community-join-btn.joined {
  background: #e3f2fd;
  border-color: #90caf9;
  color: #1565c0;
}

.community-join-btn.joined:hover {
  background: #ffebee;
  border-color: #f44336;
  color: #c62828;
}

/* Community actions bar */
.community-actions-bar {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}

.community-action-btn {
  padding: 0.45rem 1rem;
  background: white;
  color: #2196F3;
  border: 2px solid #2196F3;
  border-radius: 20px;
  font-weight: 600;
  font-size: 0.85rem;
  cursor: pointer;
  transition: all 0.2s;
}

.community-action-btn:hover {
  background: #2196F3;
  color: white;
}

/* Post title link in feed */
.post-title-link {
  text-decoration: none;
  color: inherit;
}

.post-title-link:hover .post-title {
  color: #2196F3;
}

/* ============================
   POST DETAIL PAGE (Reddit-style dark)
   ============================ */
.pd-wrapper {
  max-width: 780px;
  margin: 0 auto;
  padding: 1rem 0.5rem;
}

.pd-container {
  background: #1a1a1b;
  border-radius: 12px;
  padding: 1.25rem 1.5rem;
  color: #d7dadc;
}

.pd-loading {
  text-align: center;
  padding: 3rem;
  color: #818384;
  font-size: 1rem;
}

/* Top bar: back + community + time */
.pd-top-bar {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}

.pd-back-btn {
  background: none;
  border: none;
  color: #d7dadc;
  font-size: 1.3rem;
  cursor: pointer;
  padding: 0.2rem 0.4rem;
  border-radius: 50%;
  line-height: 1;
  transition: background 0.15s;
}

.pd-back-btn:hover {
  background: #2a2a2b;
}

.pd-community-badge {
  display: flex;
  align-items: center;
  gap: 0.3rem;
}

.pd-community-icon {
  font-size: 0.9rem;
}

.pd-community-name {
  font-weight: 700;
  font-size: 0.85rem;
  color: #d7dadc;
}

.pd-header-dot {
  color: #818384;
  font-size: 0.75rem;
}

.pd-header-time {
  color: #818384;
  font-size: 0.8rem;
}

/* Author row */
.pd-author-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.6rem;
}

.pd-author-avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: 700;
  font-size: 0.75rem;
  flex-shrink: 0;
}

.pd-author-name {
  font-size: 0.8rem;
  color: #818384;
  font-weight: 500;
}

/* Title */
.pd-title {
  font-size: 1.35rem;
  font-weight: 700;
  color: #d7dadc;
  line-height: 1.3;
  margin-bottom: 0.75rem;
}

/* Image */
.pd-image {
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 0.75rem;
  background: #000;
}

.pd-image img {
  width: 100%;
  display: block;
  object-fit: contain;
  max-height: 520px;
}

/* Content */
.pd-content {
  font-size: 0.92rem;
  color: #b0b3b8;
  line-height: 1.55;
  margin-bottom: 0.75rem;
  white-space: pre-wrap;
}

/* Action bar */
.pd-action-bar {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0;
  margin-bottom: 0.5rem;
  border-bottom: 1px solid #343536;
}

.pd-action-bar .post-vote-pill {
  background: #272729;
}

.pd-action-bar .post-vote-count {
  color: #d7dadc;
}

.pd-action-pill {
  background: #272729;
  border: none;
  color: #818384;
  font-size: 0.8rem;
  font-weight: 600;
  padding: 0.4rem 0.75rem;
  border-radius: 20px;
  cursor: pointer;
  transition: background 0.15s;
}

.pd-action-pill:hover {
  background: #3a3a3c;
  color: #d7dadc;
}

.pd-action-pill.pd-delete:hover {
  background: #4a2020;
  color: #ff6b6b;
}

/* Comment input */
.pd-comment-input-wrapper {
  margin-bottom: 1rem;
}

.pd-comment-form {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}

.pd-comment-input-avatar {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: 700;
  font-size: 0.75rem;
  flex-shrink: 0;
}

.pd-comment-input {
  flex: 1;
  background: #272729;
  border: 1px solid #343536;
  border-radius: 20px;
  padding: 0.6rem 1rem;
  color: #d7dadc;
  font-size: 0.88rem;
  outline: none;
  transition: border-color 0.2s;
}

.pd-comment-input::placeholder {
  color: #5a5c5e;
}

.pd-comment-input:focus {
  border-color: #d7dadc;
}

.pd-comment-login-prompt {
  display: block;
  text-decoration: none;
  text-align: center;
  cursor: pointer;
}

.pd-comment-login-prompt:hover {
  border-color: #d7dadc;
  color: #d7dadc;
}

.pd-comment-submit {
  background: #0079d3;
  border: none;
  color: white;
  padding: 0.45rem 1rem;
  border-radius: 20px;
  font-weight: 700;
  font-size: 0.82rem;
  cursor: pointer;
  transition: background 0.15s;
  flex-shrink: 0;
}

.pd-comment-submit:hover {
  background: #1a8cff;
}

.pd-comment-submit:disabled {
  opacity: 0.5;
  cursor: default;
}

/* Sort bar */
.pd-comment-controls {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}

.pd-sort-row {
  display: flex;
  align-items: center;
  gap: 0.35rem;
}

.pd-sort-label {
  font-size: 0.78rem;
  color: #818384;
  margin-right: 0.15rem;
}

.pd-sort-btn {
  background: none;
  border: none;
  color: #818384;
  font-size: 0.78rem;
  font-weight: 600;
  cursor: pointer;
  padding: 0.25rem 0.5rem;
  border-radius: 14px;
  transition: all 0.15s;
}

.pd-sort-btn:hover {
  background: #272729;
  color: #d7dadc;
}

.pd-sort-btn.active {
  background: #3a3a3c;
  color: #d7dadc;
}

/* Comments list */
.pd-comments-list {
  display: flex;
  flex-direction: column;
}

.pd-no-comments {
  text-align: center;
  color: #818384;
  font-size: 0.9rem;
  padding: 1.5rem 0;
}

/* Individual comment */
.pd-comment {
  display: flex;
  gap: 0;
  padding: 0.15rem 0;
}

.pd-comment-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 32px;
  flex-shrink: 0;
}

.pd-comment-avatar {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: 700;
  font-size: 0.7rem;
  flex-shrink: 0;
}

.pd-comment-thread-line {
  width: 2px;
  flex: 1;
  background: #343536;
  margin-top: 0.3rem;
  border-radius: 1px;
}

.pd-comment-body {
  flex: 1;
  padding: 0.2rem 0 0.6rem 0.5rem;
  min-width: 0;
}

.pd-comment-header {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  margin-bottom: 0.2rem;
}

.pd-comment-author {
  font-weight: 700;
  font-size: 0.8rem;
  color: #d7dadc;
}

.pd-comment-dot {
  color: #818384;
  font-size: 0.65rem;
}

.pd-comment-time {
  font-size: 0.75rem;
  color: #818384;
}

.pd-comment-text {
  font-size: 0.88rem;
  color: #c5c8cc;
  line-height: 1.45;
  margin-bottom: 0.3rem;
  white-space: pre-wrap;
}

.pd-comment-actions {
  display: flex;
  align-items: center;
  gap: 0.1rem;
}

.pd-comment-action-btn {
  background: none;
  border: none;
  color: #818384;
  font-size: 0.75rem;
  font-weight: 600;
  cursor: pointer;
  padding: 0.2rem 0.4rem;
  border-radius: 4px;
  transition: background 0.12s, color 0.12s;
}

.pd-comment-action-btn:hover {
  background: #272729;
  color: #d7dadc;
}

.pd-comment-delete-btn:hover {
  background: #4a2020;
  color: #ff6b6b;
}

/* Comment edit mode */
.pd-comment-edit {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  margin-bottom: 0.3rem;
}

.pd-comment-edit-input {
  background: #272729;
  border: 1px solid #343536;
  border-radius: 8px;
  padding: 0.5rem 0.7rem;
  color: #d7dadc;
  font-size: 0.88rem;
  font-family: inherit;
  resize: vertical;
  outline: none;
  line-height: 1.45;
  transition: border-color 0.2s;
}

.pd-comment-edit-input:focus {
  border-color: #d7dadc;
}

.pd-comment-edit-actions {
  display: flex;
  gap: 0.4rem;
}

.pd-comment-edit-save {
  background: #0079d3;
  border: none;
  color: white;
  padding: 0.3rem 0.85rem;
  border-radius: 14px;
  font-weight: 700;
  font-size: 0.78rem;
  cursor: pointer;
  transition: background 0.15s;
}

.pd-comment-edit-save:hover {
  background: #1a8cff;
}

.pd-comment-edit-save:disabled {
  opacity: 0.5;
  cursor: default;
}

.pd-comment-edit-cancel {
  background: #272729;
  border: none;
  color: #818384;
  padding: 0.3rem 0.85rem;
  border-radius: 14px;
  font-weight: 600;
  font-size: 0.78rem;
  cursor: pointer;
  transition: background 0.15s;
}

.pd-comment-edit-cancel:hover {
  background: #3a3a3c;
  color: #d7dadc;
}

/* Reply form */
.pd-reply-form {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-top: 0.4rem;
  margin-bottom: 0.25rem;
}

.pd-reply-avatar {
  width: 22px;
  height: 22px;
  font-size: 0.65rem;
}

.pd-reply-input {
  flex: 1;
  background: #272729;
  border: 1px solid #343536;
  border-radius: 16px;
  padding: 0.4rem 0.75rem;
  color: #d7dadc;
  font-size: 0.82rem;
  outline: none;
  transition: border-color 0.2s;
}

.pd-reply-input::placeholder {
  color: #5a5c5e;
}

.pd-reply-input:focus {
  border-color: #d7dadc;
}

.pd-reply-submit {
  padding: 0.3rem 0.75rem;
  font-size: 0.76rem;
}

/* Nested replies */
.pd-replies {
  margin-top: 0.15rem;
}
