        }

        public async Task AddAsync(Platform platform)
        {
            await _context.Platforms.AddAsync(platform);
        }

        public void Delete(Platform platform)
        {
            _context.Platforms.Remove(platform);
        }

        public void Update(Platform platform)
        {
            _context.Platforms.Update(platform);
        }

        //game
        public IQueryable<Game> GameGetAll(Expression<Func<Game,
            bool>>? expression = null,
            Expression<Func<Game,
                object>>? orderExpression = null,
            int skip = 0,
            int take = 0,
            bool isDescending = false,
            bool isTracking = false,
            params string[]? includes)
        {
            IQueryable<Game> query = _context.Games.Include(g => g.Category).Include(g => g.GamePlatforms).OrderBy(c => c.Name);

            if (expression != null)
                query = query.Where(expression);

            if (includes != null)
            {
                foreach (var include in includes)
                {
                    query = query.Include(include);
