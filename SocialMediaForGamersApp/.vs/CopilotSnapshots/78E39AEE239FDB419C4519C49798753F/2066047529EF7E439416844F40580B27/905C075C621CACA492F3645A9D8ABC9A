import { useState, useEffect } from 'react'
import { getCategories, createCategory } from '../api'

export default function CategoriesList() {
  const [categories, setCategories] = useState([])
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState(null)
  const [newName, setNewName] = useState('')
  const [showForm, setShowForm] = useState(false)

  useEffect(() => {
    fetchCategories()
  }, [])

  const fetchCategories = async () => {
    try {
      setLoading(true)
      setError(null)
      console.log('Fetching categories from: http://localhost:5000/api/category')
      const response = await getCategories(1, 10)
      console.log('Categories response:', response.data)
      setCategories(response.data)
    } catch (err) {
      console.error('Full error:', err)
      const errorMsg = err.response?.data?.message || err.message || 'Unknown error'
      setError('Failed to load categories: ' + errorMsg)
    } finally {
      setLoading(false)
    }
  }

  const handleSubmit = async (e) => {
    e.preventDefault()
    if (!newName.trim()) return

    try {
      setError(null)
      await createCategory({ name: newName })
      setNewName('')
      setShowForm(false)
      fetchCategories()
    } catch (err) {
      console.error('Create error:', err)
      const errorMsg = err.response?.data?.message || err.message || 'Unknown error'
      setError('Failed to create category: ' + errorMsg)
    }
  }

  if (loading) return <div className="loading">Loading categories...</div>
  if (error) return <div className="error">{error}</div>

  return (
    <div>
      <button onClick={() => setShowForm(!showForm)}>
        {showForm ? 'Cancel' : 'Add Category'}
      </button>

      {showForm && (
        <form onSubmit={handleSubmit} style={{ marginTop: '1rem' }}>
          <div className="form-group">
            <label>Category Name</label>
            <input
              type="text"
              value={newName}
              onChange={(e) => setNewName(e.target.value)}
              placeholder="e.g., RPG, FPS, Strategy"
              required
            />
          </div>
          <button type="submit">Create Category</button>
        </form>
      )}

      <div style={{ marginTop: '1rem' }}>
        {categories.length === 0 ? (
          <p>No categories yet. Create one!</p>
        ) : (
          <div className="grid">
            {categories.map(cat => (
              <div key={cat.id} className="card">
                <h3>{cat.name}</h3>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  )
}
