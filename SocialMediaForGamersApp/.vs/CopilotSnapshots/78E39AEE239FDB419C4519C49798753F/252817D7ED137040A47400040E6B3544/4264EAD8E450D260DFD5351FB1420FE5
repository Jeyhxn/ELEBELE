import { useState, useEffect } from 'react'
import { getGames } from '../api'

export default function GamesList() {
  const [games, setGames] = useState([])
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState(null)

  useEffect(() => {
    fetchGames()
  }, [])

  const fetchGames = async () => {
    try {
      setLoading(true)
      setError(null)
      console.log('Fetching games from: https://localhost:7271/api/game')
      const response = await getGames(1, 20)
      console.log('Games response:', response.data)
      setGames(response.data)
    } catch (err) {
      console.error('Full error:', err)
      const errorMsg = err.response?.data?.message || err.message || 'Unknown error'
      setError('Failed to load games: ' + errorMsg)
    } finally {
      setLoading(false)
    }
  }

  const getImageUrl = (imageURL, gameName) => {
    if (!imageURL) return getPlaceholderImage(gameName)

    // If it's already a full URL (starts with http/https)
    if (imageURL.startsWith('http')) return imageURL

    // If it's just a filename, prepend the backend base URL
    // Assuming images are served from the backend server
    return `https://localhost:7271/images/${imageURL}`
  }

  const getPlaceholderImage = (gameName) => {
    // Generate a solid color based on game name hash
    const colors = ['FF6B6B', '4ECDC4', '45B7D1', 'FFA07A', '98D8C8', 'F7DC6F', 'BB8FCE', '85C1E2']
    const hash = gameName.charCodeAt(0)
    const color = colors[hash % colors.length]
    return `https://via.placeholder.com/300x400/` + color + `/FFFFFF?text=` + encodeURIComponent(gameName)
  }

  if (loading) return <div className="loading">Loading games...</div>
  if (error) return <div className="error">{error}</div>

  return (
    <div>
      {games.length === 0 ? (
        <p>No games found. Create one to get started!</p>
      ) : (
        <div className="games-grid">
          {games.map(game => (
            <div key={game.id} className="game-card">
              <div className="game-image-container">
                <img 
                  src={getImageUrl(game.imageURL, game.name)}
                  alt={game.name}
                  className="game-image"
                  onError={(e) => {
                    console.warn(`Image failed to load for ${game.name}, using placeholder`)
                    e.target.src = getPlaceholderImage(game.name)
                  }}
                  onLoad={() => {
                    console.log(`Image loaded for ${game.name}`)
                  }}
                />
              </div>
              <div className="game-info">
                <h3>{game.name}</h3>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  )
}
