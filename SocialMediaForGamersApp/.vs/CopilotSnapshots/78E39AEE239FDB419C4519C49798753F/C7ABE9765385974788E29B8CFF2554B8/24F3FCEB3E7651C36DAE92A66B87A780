import { useState, useEffect } from 'react'
import { getGames } from '../api'

export default function GamesList() {
  const [games, setGames] = useState([])
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState(null)

  useEffect(() => {
    fetchGames()
  }, [])

  const fetchGames = async () => {
    try {
      setLoading(true)
      setError(null)
      console.log('Fetching games from: http://localhost:5000/api/game')
      const response = await getGames(1, 10)
      console.log('Games response:', response.data)
      setGames(response.data)
    } catch (err) {
      console.error('Full error:', err)
      const errorMsg = err.response?.data?.message || err.message || 'Unknown error'
      setError('Failed to load games: ' + errorMsg)
    } finally {
      setLoading(false)
    }
  }

  if (loading) return <div className="loading">Loading games...</div>
  if (error) return <div className="error">{error}</div>

  return (
    <div>
      {games.length === 0 ? (
        <p>No games found. Create one to get started!</p>
      ) : (
        <div className="grid">
          {games.map(game => (
            <div key={game.id} className="card">
              <h3>{game.name}</h3>
              <p>{game.description}</p>
              <div style={{ fontSize: '0.9rem', color: '#666' }}>
                <p><strong>Developer:</strong> {game.developer}</p>
                <p><strong>Publisher:</strong> {game.publisher}</p>
                <p><strong>Rating:</strong> {game.rating}/10</p>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  )
}
